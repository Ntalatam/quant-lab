# ── Database ──
DATABASE_URL=postgresql+asyncpg://quantlab:quantlab@localhost:5432/quantlab
# For local dev without Docker: sqlite+aiosqlite:///./quantlab.db

# ── Server ──
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # true for structured JSON logs in production
SLOW_REQUEST_THRESHOLD_MS=750.0

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]

# ── Auth ──
AUTH_SECRET_KEY=change-me-before-production
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_NAME=quantlab_refresh_token
AUTH_COOKIE_SECURE=false      # set true behind HTTPS
AUTH_COOKIE_SAMESITE=lax
JOB_WORKER_POLL_INTERVAL_SECONDS=1.0
JOB_MAX_ATTEMPTS=1

# ── External APIs ──
FRED_API_KEY=                # optional — FRED economic data
MARKET_DATA_PROVIDER=yfinance
ECONOMIC_DATA_PROVIDER=fred
EARNINGS_DATA_PROVIDER=yfinance
NEWS_SENTIMENT_PROVIDER=yfinance
ASSET_METADATA_PROVIDER=yfinance
ALPACA_API_KEY=             # optional — enables broker paper sessions via Alpaca
ALPACA_SECRET_KEY=          # optional — enables broker paper sessions via Alpaca
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Defaults ──
DEFAULT_SLIPPAGE_BPS=5.0
DEFAULT_COMMISSION_PER_SHARE=0.005
DEFAULT_INITIAL_CAPITAL=100000.0
MAX_BACKTEST_YEARS=20
